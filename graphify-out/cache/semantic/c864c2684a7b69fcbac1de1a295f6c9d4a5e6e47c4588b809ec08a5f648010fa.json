{"nodes": [{"id": "3_expectations_engineering", "label": "Engineering Expectations", "file_type": "document", "source_file": "3_expectations/engineering.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "concept_server_authoritative_validation", "label": "Server-Authoritative Validation (Django enforces business rules)", "file_type": "concept", "source_file": "3_expectations/engineering.md", "source_location": "line 7-8", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Critical business rules must be enforced in Django on the server side, not only in the React client. This prevents client-bypass of validation and keeps domain logic in a single authoritative location."}, {"id": "concept_fail_closed_default", "label": "Fail-Closed Runtime Configuration Default", "file_type": "rationale", "source_file": "3_expectations/engineering.md", "source_location": "line 53-56", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Production configuration must fail safely rather than fall back to insecure defaults. Debug or insecure fallbacks require explicit opt-in (e.g. DJANGO_DEBUG=true) to preserve local/CI ergonomics without compromising production security."}], "edges": [{"source": "3_expectations_engineering", "target": "concept_server_authoritative_validation", "relation": "implements", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "3_expectations/engineering.md", "source_location": "line 7-8", "weight": 1.0}, {"source": "3_expectations_engineering", "target": "concept_fail_closed_default", "relation": "implements", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "3_expectations/engineering.md", "source_location": "line 53-56", "weight": 1.0}, {"source": "concept_server_authoritative_validation", "target": "concept_django_backend", "relation": "conceptually_related_to", "confidence": "I